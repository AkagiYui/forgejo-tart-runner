diff --git a/act/container/tart.go b/act/container/tart.go
new file mode 100644
index 00000000..83c797ff
--- /dev/null
+++ b/act/container/tart.go
@@ -0,0 +1,135 @@
+// Copyright The Forgejo Authors.
+// SPDX-License-Identifier: MIT
+//
+// Tart back-end: run a job's steps inside a disposable Apple "tart" macOS VM.
+//
+// This reuses HostEnvironment for all file handling: the per-job work-root is
+// mounted into the VM (virtio-fs) and symlinked to the identical absolute path
+// inside the guest, so Copy/CopyDir and friends keep operating host-side while
+// commands execute in the VM via `tart exec`. The runner process itself never
+// enters the VM. VM lifecycle (clone/run/stop/delete) is driven through the
+// tart CLI, which the operator installs separately (tart is not bundled).
+package container
+
+import (
+	"context"
+	"fmt"
+	"os"
+	"os/exec"
+	"path/filepath"
+	"time"
+
+	"code.forgejo.org/forgejo/runner/v12/act/common"
+)
+
+const (
+	// tartMountName is the virtio-fs share name for the work-root.
+	tartMountName = "ftrroot"
+	// tartMountGuestPath is where macOS guests auto-mount that share.
+	tartMountGuestPath = "/Volumes/My Shared Files/" + tartMountName
+)
+
+// TartBinPath resolves the tart binary on the host, falling back to "tart".
+func TartBinPath() string {
+	if p, err := exec.LookPath("tart"); err == nil {
+		return p
+	}
+	return "tart"
+}
+
+// tartExecArgv builds the argv that runs command inside the VM via the tart
+// guest agent. Everything is passed as argv elements (no shell parsing), so
+// special characters in env values or arguments are preserved:
+//
+//	tart exec <vm> /usr/bin/env FTR_WD=<wd> <K=V...> /bin/bash -lc 'cd "$FTR_WD" && exec "$@"' ftr <command...>
+//
+// A login shell is used so the guest's profile (Homebrew/node on PATH) is
+// loaded; env vars are then layered on top and the real command is exec'd in wd.
+func tartExecArgv(tartBin, vm, wd string, command []string, env map[string]string) []string {
+	argv := []string{tartBin, "exec", vm, "/usr/bin/env", "FTR_WD=" + wd}
+	for k, v := range env {
+		argv = append(argv, k+"="+v)
+	}
+	argv = append(argv, "/bin/bash", "-lc", `cd "$FTR_WD" && exec "$@"`, "ftr")
+	return append(argv, command...)
+}
+
+// tartCLI runs a tart subcommand on the host (inheriting the host environment so
+// it can find HOME/$TART_HOME) and returns combined output for diagnostics.
+func (e *HostEnvironment) tartCLI(ctx context.Context, args ...string) ([]byte, error) {
+	return exec.CommandContext(ctx, e.TartBin, args...).CombinedOutput()
+}
+
+// StartTartVM clones the base image, boots it headless with the work-root
+// (miscpath) mounted read-write, waits for the guest agent, and symlinks the
+// host work-root path to the mount inside the guest so absolute paths resolve
+// identically on both sides. It also creates the tool-cache directory.
+func (e *HostEnvironment) StartTartVM(miscpath string) common.Executor {
+	return func(ctx context.Context) error {
+		logger := common.Logger(ctx)
+
+		if out, err := e.tartCLI(ctx, "clone", e.TartImage, e.TartVM); err != nil {
+			return fmt.Errorf("tart clone %s -> %s: %w: %s", e.TartImage, e.TartVM, err, out)
+		}
+
+		runCmd := exec.Command(e.TartBin, "run", "--no-graphics", "--dir="+tartMountName+":"+miscpath, e.TartVM)
+		if logf, err := os.Create(filepath.Join(os.TempDir(), "forgejo-tart-"+e.TartVM+".run.log")); err == nil {
+			runCmd.Stdout = logf
+			runCmd.Stderr = logf
+		}
+		if err := runCmd.Start(); err != nil {
+			return fmt.Errorf("tart run %s: %w", e.TartVM, err)
+		}
+		e.tartRunCmd = runCmd
+
+		// Wait for the guest agent (tart exec) to answer.
+		ready := false
+		for i := 0; i < 90; i++ {
+			if exec.CommandContext(ctx, e.TartBin, "exec", e.TartVM, "true").Run() == nil {
+				ready = true
+				break
+			}
+			if runCmd.ProcessState != nil { // VM process exited early
+				break
+			}
+			select {
+			case <-ctx.Done():
+				return ctx.Err()
+			case <-time.After(2 * time.Second):
+			}
+		}
+		if !ready {
+			return fmt.Errorf("tart VM %s: guest agent did not become ready", e.TartVM)
+		}
+
+		// Make the host work-root path resolve inside the guest (identity path),
+		// and create the tool cache directory.
+		setup := fmt.Sprintf(`set -e; mkdir -p %q; ln -sfn %q %q; mkdir -p %q`,
+			filepath.Dir(miscpath), tartMountGuestPath, miscpath, e.ToolCache)
+		if out, err := e.tartCLI(ctx, "exec", e.TartVM, "/bin/bash", "-lc", setup); err != nil {
+			return fmt.Errorf("tart VM %s setup: %w: %s", e.TartVM, err, out)
+		}
+
+		logger.Infof("tart VM %s ready (image %s)", e.TartVM, e.TartImage)
+		return nil
+	}
+}
+
+// StopTartVM stops and deletes the per-job VM clone and reaps the `tart run`
+// process. Best-effort: errors are ignored so cleanup always proceeds.
+func (e *HostEnvironment) StopTartVM(ctx context.Context) error {
+	if e.TartVM == "" {
+		return nil
+	}
+	_, _ = e.tartCLI(ctx, "stop", "--timeout", "15", e.TartVM)
+	if e.tartRunCmd != nil && e.tartRunCmd.Process != nil {
+		_ = e.tartRunCmd.Process.Kill()
+	}
+	for i := 0; i < 10; i++ {
+		if exec.Command(e.TartBin, "delete", e.TartVM).Run() == nil {
+			break
+		}
+		time.Sleep(time.Second)
+	}
+	return nil
+}
