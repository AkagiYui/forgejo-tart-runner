+		}
 		actPath := filepath.Join(miscpath, "act")
 		if err := os.MkdirAll(actPath, 0o777); err != nil {
 			return err
@@ -331,7 +344,7 @@ func (rc *RunContext) startHostEnvironment() common.Executor {
 		if err := os.MkdirAll(runnerTmp, 0o777); err != nil {
 			return err
 		}
-		rc.JobContainer = &container.HostEnvironment{
+		hostEnv := &container.HostEnvironment{
 			Name:      randName,
 			Root:      miscpath,
 			Path:      path,
@@ -342,6 +355,15 @@ func (rc *RunContext) startHostEnvironment() common.Executor {
 			StdOut:    logWriter,
 			LXC:       rc.IsLXCHostEnv(ctx),
 		}
+		if rc.IsTartEnv(ctx) {
+			hostEnv.Tart = true
+			hostEnv.TartVM = "ftr-" + randName
+			hostEnv.TartImage = rc.GetTartImage(ctx)
+			hostEnv.TartBin = container.TartBinPath()
+			// The tool cache lives inside the ephemeral VM.
+			hostEnv.ToolCache = "/Users/admin/.cache/forgejo-tool-cache"
+		}
+		rc.JobContainer = hostEnv
 		rc.cleanUpJobContainer = func(ctx context.Context) error {
 			if err := rc.stopHostEnvironment(ctx); err != nil {
 				return err
@@ -367,6 +389,12 @@ func (rc *RunContext) startHostEnvironment() common.Executor {
 
 		executors := make([]common.Executor, 0, 10)
 
+		if hostEnv.Tart {
+			// Clone + boot the per-job VM and mount the work-root before any
+			// file copies or step execution.
+			executors = append(executors, hostEnv.StartTartVM(miscpath))
+		}
+
 		isLXCHost, LXCTemplate, LXCRelease, LXCConfig := rc.GetLXCInfo(ctx)
 
 		if isLXCHost {
@@ -964,8 +992,21 @@ func (rc *RunContext) GetLXCInfo(ctx context.Context) (isLXC bool, template, rel
 	return isLXC, template, release, config
 }
 
+const tartPrefix = "tart:"
+
+// IsTartEnv reports whether the resolved platform selects the tart macOS VM
+// back-end (label scheme "tart", platform string "tart:<image>").
+func (rc *RunContext) IsTartEnv(ctx context.Context) bool {
+	return strings.HasPrefix(rc.runsOnImage(ctx), tartPrefix)
+}
+
+// GetTartImage returns the base VM image to clone for a tart job.
+func (rc *RunContext) GetTartImage(ctx context.Context) string {
+	return strings.TrimPrefix(rc.runsOnImage(ctx), tartPrefix)
+}
+
 func (rc *RunContext) IsHostEnv(ctx context.Context) bool {
-	return rc.IsBareHostEnv(ctx) || rc.IsLXCHostEnv(ctx)
+	return rc.IsBareHostEnv(ctx) || rc.IsLXCHostEnv(ctx) || rc.IsTartEnv(ctx)
 }
 
 func (rc *RunContext) stopContainer() common.Executor {
